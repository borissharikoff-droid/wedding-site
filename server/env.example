# Railway injects DATABASE_URL automatically when a Postgres plugin is
# attached to this service - no need to set it manually in production.
DATABASE_URL=postgres://user:password@localhost:5432/wedding_rsvp

# Secret key required in the "x-admin-key" header to read the guest list
# (GET /api/rsvp). Set a real random value in Railway service variables.
ADMIN_KEY=change-me

# Comma-separated list of allowed origins for CORS. Set to your real site
# origin(s) in production, e.g. https://your-wedding-site.example
CORS_ORIGIN=*

PORT=3000
